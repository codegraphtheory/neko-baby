#!/usr/bin/env bash
set -euo pipefail

profile="neko-baby"
font_name="${NEKO_BABY_TERMINAL_FONT:-Comic Mono}"
font_size="${NEKO_BABY_TERMINAL_FONT_SIZE:-14}"
restore_font="${NEKO_BABY_RESTORE_FONT:-1}"
hermes_bin="${HERMES_BIN:-$(command -v hermes)}"

orig_font=""
orig_size=""
font_applied="0"

terminal_get() {
  osascript -e 'tell application "Terminal" to if (count of windows) > 0 then get font name of selected tab of front window' 2>/dev/null || true
}

terminal_size() {
  osascript -e 'tell application "Terminal" to if (count of windows) > 0 then get font size of selected tab of front window' 2>/dev/null || true
}

terminal_set() {
  local name="$1"
  local size="$2"
  osascript <<OSA >/dev/null 2>&1 || true
tell application "Terminal"
  if (count of windows) > 0 then
    set font name of selected tab of front window to "$name"
    set font size of selected tab of front window to $size
  end if
end tell
OSA
}

restore_terminal_font() {
  if [ "$font_applied" = "1" ] && [ "$restore_font" != "0" ] && [ -n "$orig_font" ] && [ -n "$orig_size" ]; then
    terminal_set "$orig_font" "$orig_size"
  fi
}

if [ "$(uname -s)" = "Darwin" ] && osascript -e 'id of application "Terminal"' >/dev/null 2>&1; then
  orig_font="$(terminal_get)"
  orig_size="$(terminal_size)"
  terminal_set "$font_name" "$font_size"
  font_applied="1"
  trap restore_terminal_font EXIT INT TERM
fi

"$hermes_bin" -p "$profile" "$@"
