Output assets/demos/neko-baby-terminal-demo.gif
Set Shell "bash"
Set FontFamily "Comic Mono"
Set FontSize 18
Set Width 1000
Set Height 680
Set Padding 24
Set Framerate 30
Set PlaybackSpeed 1.0
Set Theme "Catppuccin Mocha"

Type "stty cols 79; NEKO_BABY_RESTORE_FONT=0 neko-baby chat"
Enter
Sleep 7s
Type "/exit"
Enter
Sleep 1s
